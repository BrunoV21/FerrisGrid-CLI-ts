{
  "name": "ferrisgrid-cli",
  "version": "0.2.0",
  "description": "Terminal-first visual control CLI for local AI agents.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BrunoV21/FerrisGrid-CLI-ts.git"
  },
  "homepage": "https://github.com/BrunoV21/FerrisGrid-CLI-ts#readme",
  "bugs": {
    "url": "https://github.com/BrunoV21/FerrisGrid-CLI-ts/issues"
  },
  "keywords": [
    "automation",
    "screen",
    "coordinates",
    "agent",
    "cli"
  ],
  "type": "commonjs",
  "bin": {
    "ferrisgrid": "bin/ferrisgrid"
  },
  "files": [
    "bin/",
    "dist/src/",
    "rust-binaries/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test",
    "pack:dry-run": "npm pack --dry-run",
    "release:dry-run": "npm publish --dry-run"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
